{
  "extends": "@tsconfig/docusaurus/tsconfig.json",  
  "compilerOptions": {
    "lib": ["DOM"],
    "target": "ES2020",
    "module": "Node16",
    // "types": ["docusaurus-theme-frontmatter", "node"],
    "useDefineForClassFields": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0"
  }
}